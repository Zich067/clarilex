# =============================================================================
# Environment Configuration Example
# 複製此檔為 `.env` 並填入實際值。`.env` 已被 .gitignore,不會進版控。
# =============================================================================

# ----- OpenAI API (主要生成 + 評審;required) -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
JUDGE_MODEL=gpt-5-mini
# gpt-5 / o-series 推理深度: low / medium / high
#   low: 預設,結構化 CoT (IRAC) 已足夠
#   medium: 多條法規綜合判斷可考慮 (延遲 ~2.5x)
#   high: 複雜稅務/繼承爭議 (延遲 ~6x,CP 值低)
OPENAI_REASONING_EFFORT=low

# ----- Gemini (跨模型穩健性對照;經 OpenAI 相容介面;model 以 "gemini" 開頭即走此路徑) -----
# Key 取得: Google AI Studio (aistudio.google.com)。非中國大陸、與 OpenAI 並存。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ----- Embedding (本地、開放權重;升級後改此處 + 重建索引) -----
# 正式: Snowflake/snowflake-arctic-embed-l-v2.0 (1024 維,非陸源、本地離線;論文 §6.3 正式檢索模型)
# baseline 對照(§6.3.2): 改回 paraphrase-multilingual-MiniLM-L12-v2 + EMBEDDING_DIM=384
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
EMBEDDING_DIM=1024

# ----- Reranker (cross-encoder 精排;空字串=不啟用,退回純向量檢索) -----
# 升級後填入選定之非大陸本地 reranker(e.g. jina-reranker-v2-multilingual)
RERANKER_MODEL=
# reranker 啟用時之候選池大小: 嵌入撈 RETRIEVAL_POOL → 精排 → 留 MAX_RETRIEVAL_K
RETRIEVAL_POOL=20

# ----- Retrieval -----
MAX_RETRIEVAL_K=3
# 條號命中加權 λ: s(q,c)=cos + λ·𝟙[art(q)∩art(c)≠∅] (§3.3.5)
ARTICLE_BOOST_LAMBDA=0.2

# ----- 向量索引路徑 (chroma;須純 ASCII 路徑,避免 chroma-hnswlib C++ fopen 限制) -----
# 未設則用預設 (~/.thesis-system/indexes/);本研究實驗用 data/chroma
# THESIS_INDEX_DIR=

# ----- ChromaDB -----
CHROMA_PERSIST_DIR=./chroma_db

# ----- FastAPI -----
API_HOST=0.0.0.0
API_PORT=8000

# ----- Frontend (Next.js 呼叫後端之 URL;前端 web/.env.local 對應) -----
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ----- Mock fallback (key 缺失或 API 失敗時是否啟用 mock;驗證/實驗時務必 false) -----
MOCK_FALLBACK=true
